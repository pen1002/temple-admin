generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 사찰 기본 정보 (munsusa-site와 동일 DB 공유)
model Temple {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nameEn         String?
  description    String?  @db.Text
  logoUrl        String?
  heroImageUrl   String?
  address        String?
  phone          String?
  email          String?
  primaryColor   String   @default("#8B2500")
  secondaryColor String   @default("#C5A572")
  fontFamily     String   @default("Pretendard")
  customDomain   String?  @unique
  subdomain      String?  @unique
  denomination   String?
  foundedYear    Int?
  abbotName      String?
  tier           Int      @default(1)
  themeType      String   @default("theme-2")
  themeColor     String?  @default("golden-lotus")
  pageTemplate   String   @default("standard")
  pin            String   @default("0000")
  status         String   @default("active")
  isActive       Boolean  @default(true)
  temple_type    String   @default("offline")
  kakao_notify_tel String?
  bank_name      String?
  bank_account   String?
  bank_holder    String?
  contact_tel    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blockConfigs          BlockConfig[]
  believers             Believer[]
  wisdomOverrides       TempleWisdomOverride[]

  @@index([code])
}

model BlockConfig {
  id        String   @id @default(cuid())
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  blockType String
  label     String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templeId, order])
  @@index([templeId, blockType])
}

// 일별 법문 인용구
model DharmaQuote {
  id          Int      @id @default(autoincrement())
  dayIndex    Int      @unique
  text        String   @db.Text
  source      String?
  category    String?
  isSpecial   Boolean  @default(false)
  specialDate String?
  createdAt   DateTime @default(now())
}

// 365일 오늘의 부처님말씀 공통 데이터
model DailyWisdom {
  id        String   @id @default(cuid())
  monthDay  String   @unique  // e.g. "04-06"
  title     String
  content   String   @db.Text
  source    String
  verse     String?
  createdAt DateTime @default(now())
}

// 사찰별 부처님말씀 Override
model TempleWisdomOverride {
  id        String   @id @default(cuid())
  templeId  String
  monthDay  String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  temple    Temple   @relation(fields: [templeId], references: [id])

  @@unique([templeId, monthDay])
}

// 블록 카탈로그 — 어드민에서 블록 종류·defaultProps·adminSchema 관리
model BlockCatalog {
  id           String   @id @default(cuid())
  blockId      String   @unique  // e.g. "h06-chunguansa-main"
  blockType    String             // e.g. "TempleH06Hero"
  blockVersion String   @default("1.0.0")
  blockLabel   String             // e.g. "H-06 황금 연등 히어로"
  previewPath  String?            // e.g. "/block-preview/H-06"
  status       String   @default("published")
  siteId       String?
  defaultProps Json     @default("{}")
  adminSchema  Json     @default("{}")
  seo          Json     @default("{}")
  meta         Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([blockType])
  @@index([siteId])
}

model IndungDonor {
  id             BigInt   @id @default(autoincrement())
  temple_slug    String   @default("cheongwansa")
  name           String
  wish           String?
  amount         Int      @default(10000)
  bank_confirmed Boolean  @default(false)
  lantern_count  Int      @default(1)
  phase          Int      @default(1)
  contact        String   @default("")
  created_at     DateTime @default(now())

  @@map("indung_donors")
}

model CyberOffering {
  id             BigInt   @id @default(autoincrement())
  temple_slug    String
  type           String   // 'bow' | 'memorial' | 'prayer' | 'candle'
  name           String
  contact        String   @default("")
  deceased       String?
  relationship   String?
  prayer_kind    String?
  wish           String?  @db.Text
  amount         Int      @default(0)
  bank_confirmed Boolean  @default(false)
  created_at     DateTime @default(now())

  @@index([temple_slug, type, created_at])
  @@map("cyber_offerings")
}

// 지능형 신도 대장 (가람지기 호환)
model Believer {
  id              String    @id @default(uuid())
  temple_id       String?
  temple          Temple?   @relation(fields: [temple_id], references: [id])

  // 인적 사항
  full_name       String                                    // 성명
  buddhist_name   String?                                   // 법명
  gender          String?                                   // 성별 (남/여)
  birth_date      DateTime? @db.Date                        // 생년월일
  is_lunar        Boolean   @default(true)                  // 음력 여부

  // 연락 및 소통
  phone           String?                                   // 연락처
  address         String?                                   // 주소

  // 가족 연합 (세주 중심 관리)
  family_id       String?                                    // 가족 고유 ID
  family_relation String?                                   // 세주와의 관계

  // 신도 관리
  status          String    @default("활동")                // 활동/휴면/망자/탈퇴
  initiation_date DateTime? @db.Date                        // 수계/입교일
  memo            String?   @db.Text                        // 비고

  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([full_name])
  @@index([phone])
  @@index([temple_id])
  @@index([family_id])
  @@map("believers")
}
