generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 사찰 기본 정보 (munsusa-site와 동일 DB 공유)
model Temple {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nameEn         String?
  description    String?  @db.Text
  logoUrl        String?
  heroImageUrl   String?
  address        String?
  phone          String?
  email          String?
  primaryColor   String   @default("#8B2500")
  secondaryColor String   @default("#C5A572")
  fontFamily     String   @default("Pretendard")
  customDomain   String?  @unique
  subdomain      String?  @unique
  denomination   String?
  foundedYear    Int?
  abbotName      String?
  tier           Int      @default(1)
  themeType      String   @default("theme-2")
  themeColor     String?  @default("golden-lotus")
  pageTemplate   String   @default("standard")
  pin            String   @default("0000")
  status         String   @default("active")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blockConfigs BlockConfig[]

  @@index([code])
}

model BlockConfig {
  id        String   @id @default(cuid())
  templeId  String
  temple    Temple   @relation(fields: [templeId], references: [id], onDelete: Cascade)
  blockType String
  label     String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templeId, order])
  @@index([templeId, blockType])
}

// 일별 법문 인용구
model DharmaQuote {
  id          Int      @id @default(autoincrement())
  dayIndex    Int      @unique
  text        String   @db.Text
  source      String?
  category    String?
  isSpecial   Boolean  @default(false)
  specialDate String?
  createdAt   DateTime @default(now())
}

// 블록 카탈로그 — 어드민에서 블록 종류·defaultProps·adminSchema 관리
model BlockCatalog {
  id           String   @id @default(cuid())
  blockId      String   @unique  // e.g. "h06-chunguansa-main"
  blockType    String             // e.g. "TempleH06Hero"
  blockVersion String   @default("1.0.0")
  blockLabel   String             // e.g. "H-06 황금 연등 히어로"
  previewPath  String?            // e.g. "/block-preview/H-06"
  status       String   @default("published")
  siteId       String?
  defaultProps Json     @default("{}")
  adminSchema  Json     @default("{}")
  seo          Json     @default("{}")
  meta         Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([blockType])
  @@index([siteId])
}
